@model dev_ops_project.Models.ViewModels.DashboardViewModel

<h1>Dashboard</h1>

<h2>Balance</h2>
<p>@Model.Balance</p>

<h2>Total Income</h2>
<p>@Model.TotalIncome</p>

<h2>Total Expense</h2>
<p>@Model.TotalExpense</p>

<h2>Recent Transactions</h2>

<table class="table">
    <thead>
        <tr>
            <th>Date</th>
            <th>Description</th>
            <th>Category</th>
            <th>Amount</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var transaction in Model.RecentTransaction)
        {
            <tr>
                <td>@transaction.Date.ToShortDateString()</td>
                <td>@transaction.Description</td>
                <td>@transaction.Category?.Name</td>
                <td>@transaction.Amount</td>
            </tr>
        }
    </tbody>
</table>